# Required: Groq API key for all AI tools
# Get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Base URL for tests and AI tools (defaults to https://cal.com)
BASE_URL=https://cal.com

# Optional: Host name used in booking flow tests (defaults to 'Bailey Pumfleet')
HOST_NAME=Bailey Pumfleet

# Optional: Booking path appended to BASE_URL (defaults to /bailey/chat)
BOOKING_PATH=/bailey/chat

# Optional: Short label for the target app, shown in CLI help and logs
# QA_TARGET_NAME=cal.com

# Optional: Sentence injected into LLM prompts to describe the target app.
# Override when pointing at something other than cal.com.
# QA_TARGET_DESCRIPTION=a scheduling and booking platform (the default example is cal.com)

# Optional: Cache Groq responses on disk under .cache/groq/<hash>.json
# Useful during development to avoid burning API quota on identical prompts.
# GROQ_CACHE=1

# Optional: Log every retry and the final per-call token count to stderr.
# GROQ_VERBOSE=1
