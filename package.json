{
  "name": "qa-playwright",
  "version": "1.0.0",
  "description": "AI-native QA toolkit for Playwright",
  "scripts": {
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "check:docs": "tsx scripts/check-readme.ts",
    "check:secrets": "tsx scripts/check-secrets.ts --all",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "visual-regression": "tsx ai-tools/visual-regression.ts",
    "analyze-failure": "tsx ai-tools/analyze-failure.ts",
    "browser-agent": "tsx ai-tools/browser-agent.ts",
    "coverage-advisor": "tsx ai-tools/coverage-advisor.ts",
    "cdp-inspector": "tsx ai-tools/cdp-inspector.ts",
    "data-consistency": "tsx ai-tools/data-consistency.ts",
    "generate-tests": "tsx ai-tools/generate-tests.ts",
    "persona-engine": "tsx ai-tools/persona-engine.ts",
    "heal-locator": "tsx ai-tools/locator-healer.ts",
    "mcp-server": "tsx mcp-server.ts",
    "test:ai-generated": "RUN_AI_GENERATED=1 playwright test --project=ai-quarantine",
    "test:toolkit": "playwright test --project=toolkit",
    "test:examples": "playwright test --project=examples-chromium --project=examples-firefox --project=examples-webkit",
    "test:chromium": "playwright test --project=examples-chromium",
    "test:firefox": "playwright test --project=examples-firefox",
    "test:webkit": "playwright test --project=examples-webkit",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "keywords": [
    "playwright",
    "ai",
    "qa",
    "testing",
    "mcp",
    "llm"
  ],
  "author": "X",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/mcp": "^0.0.68",
    "dotenv": "^17.3.1",
    "groq-sdk": "^1.1.1",
    "zod": "^4.3.6"
  }
}
